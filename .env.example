# DB Configuration
# Produccion: Usa el connection string de Supabase Pooler (transaction mode recomendado)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/propsys
# Recomendado 3 para Render/Supabase pooler en entornos concurrentes
DATABASE_POOL_MAX=3

# Application Environment & Security
# DATA_MODE: 'db' para produccion. 'mock' solo para tests locales sin persistencia.
DATA_MODE=db
NEXT_PUBLIC_DATA_MODE=db
# NUNCA activar en produccion. Si es 1, expone tokens de auth/reset en la respuesta API para debug.
PROPSYS_EXPOSE_AUTH_TOKENS=0
# NUNCA activar en produccion.
ALLOW_MOCK_MODE=0
NEXT_PUBLIC_ALLOW_MOCK_MODE=0

# Onboarding & QA
# Solo para seed inicial de DB en local/QA. No es un secreto persistente de produccion.
PROPSYS_QA_SEED_PASSWORD=replace-with-local-qa-password

# Canonical URLs
# En Render/Produccion: DEBEN usar HTTPS y coincidir con el dominio real (e.g. https://app.propsys.com)
PROPSYS_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email Provider (Resend)
# Reemplaza re_xxxxxxxxx por tu API key real de Resend
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL="PropSys <onboarding@resend.dev>"

# Supabase Infrastructure
SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY: Server-only. NUNCA agregar prefijo NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_PAYMENT_PROOFS_BUCKET=propsys-payment-proofs
SUPABASE_STORAGE_EVIDENCE_BUCKET=propsys-operation-evidence
